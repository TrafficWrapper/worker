# Public ports exposed by this worker.
XRAY_PORT=2053
AWG_PORT=51888
AGENT_PORT=9090

# AWG addressing inside the worker data plane.
AWG_SUBNET=10.13.13.0/24
AWG_GATEWAY=10.13.13.1
# Server-side AWG peer keepalive policy. Change and restart agent + awg-gw
# together for an emergency rollback; clients keep their independent policy.
AWG_SERVER_KEEPALIVE=0

# Orchestrator enrollment and pinning.
# Same-host Docker: use https://host.docker.internal:9091.
# Remote ORCH: use its public ORCH_PUBLIC_URL.
ORCH_URL=
ORCH_STATIC_PUBLIC_KEY=
# Required for the default self-signed ORCH_TLS=1. Keep 0 with real production TLS.
ORCH_INSECURE_TLS=0
ENROLL_TOKEN=

# Public worker identity advertised to clients.
PUBLIC_ADDRESS=
# Explicit public egress IP. If empty, the agent probes public echo-IP services.
EGRESS_IP=
CAPACITY=32

# In-tunnel distributor and agent endpoints.
DISTRIBUTOR_URL=http://awg-gw:8080/tw
WORKER_AGENT_URL=

# REALITY camouflage and upstream destination.
# Required: set a real TLS 1.3 SNI/fallback domain. The agent refuses empty
# values and public placeholders such as example.com/example.org.
CAMOUFLAGE_DOMAIN=
REALITY_DEST=awg-gw:9443
XRAY_NETWORK=tcp
XRAY_XHTTP_PATH=
XRAY_XHTTP_MODE=
XRAY_XHTTP_HOST=
XRAY_XHTTP_EXTRA_JSON=

# Optional nft/firewall automation used by install.sh.
WAN_IF=
APPLY_NFT=0
EGRESS_VIA_WG=

# Optional local state and docker integration overrides.
WORKER_STATE_DIR=/worker-state
AWG_UAPI_SOCKET=/var/run/wireguard/awg1.sock
XRAY_CONTAINER_NAME=worker-xray-1
DOCKER_SOCKET=/var/run/docker.sock

# Optional advanced dialect override. JSON must match the worker dialect schema.
TW_WORKER_DIALECT_JSON=

# Optional awg-gw stub/debug variables.
SERVICE_NAME=awg-gw
AWG_LISTEN_UDP=51821

# Optional awg-smoke profile overrides.
AWG_ENDPOINT=host.docker.internal:51888
TW_SMOKE_URL=http://10.13.13.1/tw/healthz
AWG_CLIENT_PRIVATE_KEY=
AWG_CLIENT_PSK=
AWG_CLIENT_IP=

# Optional install.sh controls.
COMPOSE="docker compose"
REALITY_PORT_POOL="8444 2053 2083"
AWG_PORT_POOL="51888 51889 51890 51891"
